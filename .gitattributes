# Enforce LF line endings for all text files
* text=auto eol=lf

# Ensure these are always LF
*.cs text eol=lf
*.xaml text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.swift text eol=lf
*.rs text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.ps1 text eol=lf
*.sh text eol=lf
*.udl text eol=lf

# Binary files
*.png binary
*.ico binary
*.dll binary
*.dylib binary
*.a binary
