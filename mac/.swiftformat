# SwiftFormat Configuration — Pablo Companion

# Indentation
--indent 4
--indentcase false
--smarttabs disabled

# Wrapping
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--wrapconditions after-first
--wrapreturntype preserve
--maxwidth 120
--closingparen balanced

# Braces (K&R style)
--allman false

# Imports
--importgrouping alphabetized

# Types
--selfrequired
--redundanttype inferred

# Void
--voidtype void

# Semicolons
--semicolons never

# Trailing commas
--commas always

# Blank lines
--trimwhitespace always
--emptybraces no-space

# Ranges
--ranges spaced

# Ifdef
--ifdef no-indent

# Mark extensions
--extensionacl on-declarations

# Header
--header strip

# Modifier order (match SwiftLint: nonisolated before access control)
--modifierorder nonisolated,override,private,fileprivate,internal,public,open,final,static,class,lazy,required,convenience,optional,dynamic

# Disable rules that conflict with SwiftUI / project preferences
--disable blankLinesAtStartOfScope
--disable blankLinesAtEndOfScope
--disable redundantSelf

# Swift version
--swiftversion 6.0

# Exclude generated files (UniFFI Swift bindings — not hand-authored)
--exclude PabloCompanion/Generated
