<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:uap3="http://schemas.microsoft.com/appx/manifest/uap/windows10/3"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap uap3 rescap">

  <!-- Identity values reserved in Microsoft Partner Center for Pablo Health, LLC.
       Store ID: 9N0260HFX1JC
       Listing : https://apps.microsoft.com/detail/9N0260HFX1JC -->
  <Identity
    Name="PabloHealthLLC.PabloHealth"
    Publisher="CN=42DEB728-5FF9-4489-A5D8-F80DC15B972F"
    Version="1.0.0.0" />

  <Properties>
    <!-- Must match a name reserved in Partner Center -->
    <DisplayName>Pablo Health</DisplayName>
    <PublisherDisplayName>Pablo Health, LLC</PublisherDisplayName>
    <Logo>Images\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <!-- Windows 10 1809 (Oct 2018) minimum, matches TargetPlatformMinVersion in csproj -->
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.26200.0" />
    <!-- WinAppSDK 1.8 framework — Store auto-installs as a dependency package -->
    <PackageDependency Name="Microsoft.WindowsAppRuntime.1.8" MinVersion="8000.0.0.0" Publisher="CN=Microsoft Corporation, O=Microsoft Corporation, L=Redmond, S=Washington, C=US" />
  </Dependencies>

  <Resources>
    <Resource Language="en-US" />
  </Resources>

  <Applications>
    <Application Id="App" Executable="$targetnametoken$.exe" EntryPoint="$targetentrypoint$">
      <!-- Display name "Pablo" is what users see in Start menu / taskbar.
           Store listing uses "Pablo Health" (from Properties/DisplayName above). -->
      <uap:VisualElements
        DisplayName="Pablo"
        Description="The desktop companion for therapists — records sessions and turns them into SOAP notes."
        BackgroundColor="#FDF6EC"
        Square150x150Logo="Images\Square150x150Logo.png"
        Square44x44Logo="Images\Square44x44Logo.png">
        <uap:DefaultTile
          Wide310x150Logo="Images\Wide310x150Logo.png"
          Square71x71Logo="Images\Square71x71Logo.png"
          Square310x310Logo="Images\Square310x310Logo.png"
          ShortName="Pablo">
          <uap:ShowNameOnTiles>
            <uap:ShowOn Tile="square150x150Logo" />
            <uap:ShowOn Tile="wide310x150Logo" />
            <uap:ShowOn Tile="square310x310Logo" />
          </uap:ShowNameOnTiles>
        </uap:DefaultTile>
        <uap:SplashScreen Image="Images\SplashScreen.png" BackgroundColor="#FDF6EC" />
      </uap:VisualElements>
      <Extensions>
        <!-- pablohealth:// for OAuth callback redirect (RFC 8252 §7.1).
             Replaces the loopback HTTP redirect path so the packaged app doesn't
             need CheckNetIsolation LoopbackExempt. -->
        <uap:Extension Category="windows.protocol">
          <uap:Protocol Name="pablohealth">
            <uap:DisplayName>Pablo</uap:DisplayName>
          </uap:Protocol>
        </uap:Extension>

        <!-- Domain-verified deep-link handler (App URI Handler). Routes
             https://app.pablo.health/launch/* and https://dev.pablo.health/launch/*
             to the companion for the session-start handoff. Both hosts are listed
             so one signed build serves dev and prod. Verification is by the JSON
             file each host serves at /.well-known/windows-app-web-link listing this
             package family name. The pablohealth:// scheme above stays registered
             for the OAuth callback and as the Firefox fallback. -->
        <uap3:Extension Category="windows.appUriHandler">
          <uap3:AppUriHandler>
            <uap3:Host Name="app.pablo.health" />
            <uap3:Host Name="dev.pablo.health" />
          </uap3:AppUriHandler>
        </uap3:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <!-- Required for WinUI 3 desktop apps using full Win32 surface (NAudio, etc.) -->
    <rescap:Capability Name="runFullTrust" />
    <!-- Cloud transcription, OAuth flows, backend sync -->
    <Capability Name="internetClient" />
    <!-- Session audio recording -->
    <DeviceCapability Name="microphone" />
  </Capabilities>
</Package>
