<ContentDialog
    x:Class="PabloCompanion.Views.SessionDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PabloCompanion.Views"
    Title="Session Details"
    CloseButtonText="Close"
    DefaultButton="Close"
    FullSizeDesired="False"
    Closing="Dialog_Closing">

    <ScrollViewer MaxHeight="500" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="20" MinWidth="400">

            <!-- Patient header -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="48" Height="48"
                        CornerRadius="24"
                        Background="{StaticResource PabloHoney}">
                    <TextBlock x:Name="InitialsText"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White" />
                </Border>

                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                    <TextBlock x:Name="PatientNameText"
                               Style="{StaticResource PabloBodyLarge}"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="DateText"
                               Style="{StaticResource PabloBodySmall}"
                               Foreground="{StaticResource PabloBrownSoft}" />
                </StackPanel>

                <local:StatusBadge x:Name="Badge"
                                   Grid.Column="2"
                                   VerticalAlignment="Center" />
            </Grid>

            <!-- Session info -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid RowSpacing="12" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Time"
                               Foreground="{StaticResource PabloBrownSoft}"
                               Style="{StaticResource PabloBodySmall}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="TimeText"
                               Style="{StaticResource PabloBodyMedium}" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Duration"
                               Foreground="{StaticResource PabloBrownSoft}"
                               Style="{StaticResource PabloBodySmall}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DurationText"
                               Style="{StaticResource PabloBodyMedium}" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Platform"
                               Foreground="{StaticResource PabloBrownSoft}"
                               Style="{StaticResource PabloBodySmall}"
                               x:Name="PlatformLabel" Visibility="Collapsed" />
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PlatformText"
                               Style="{StaticResource PabloBodyMedium}"
                               Visibility="Collapsed" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Type"
                               Foreground="{StaticResource PabloBrownSoft}"
                               Style="{StaticResource PabloBodySmall}" />
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="TypeText"
                               Style="{StaticResource PabloBodyMedium}" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Notes"
                               Foreground="{StaticResource PabloBrownSoft}"
                               Style="{StaticResource PabloBodySmall}"
                               x:Name="NotesLabel" Visibility="Collapsed" />
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="NotesText"
                               Style="{StaticResource PabloBodyMedium}"
                               TextWrapping="Wrap"
                               Visibility="Collapsed" />
                </Grid>
            </Border>

            <!-- Recording section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Recording"
                           Style="{StaticResource PabloBodyLarge}"
                           FontWeight="SemiBold" />
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="16"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="RecordingText"
                                   Style="{StaticResource PabloBodyMedium}"
                                   Foreground="{StaticResource PabloBrownSoft}" />

                        <!-- Playback controls -->
                        <StackPanel x:Name="PlaybackControls" Visibility="Collapsed" Spacing="8">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button x:Name="PlayPauseButton"
                                        Grid.Column="0"
                                        Click="PlayPause_Click"
                                        Style="{StaticResource PabloPrimaryButton}"
                                        Padding="10,6"
                                        AutomationProperties.Name="Play or pause recording">
                                    <SymbolIcon x:Name="PlayPauseIcon" Symbol="Play" />
                                </Button>

                                <Button x:Name="StopButton"
                                        Grid.Column="1"
                                        Click="Stop_Click"
                                        Style="{StaticResource PabloSecondaryButton}"
                                        Padding="10,6"
                                        IsEnabled="False"
                                        AutomationProperties.Name="Stop playback">
                                    <SymbolIcon Symbol="Stop" />
                                </Button>

                                <Slider x:Name="PositionSlider"
                                        Grid.Column="2"
                                        Minimum="0"
                                        Maximum="100"
                                        Value="0"
                                        VerticalAlignment="Center"
                                        ThumbToolTipValueConverter="{x:Null}"
                                        PointerPressed="PositionSlider_PointerPressed"
                                        PointerReleased="PositionSlider_PointerReleased"
                                        AutomationProperties.Name="Playback position" />

                                <TextBlock x:Name="PositionText"
                                           Grid.Column="3"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource PabloBodySmall}"
                                           Foreground="{StaticResource PabloBrownSoft}"
                                           Text="0:00 / 0:00" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Transcript section -->
            <StackPanel Spacing="8" x:Name="TranscriptSection" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Transcript"
                               Style="{StaticResource PabloBodyLarge}"
                               FontWeight="SemiBold" />
                    <Button x:Name="ViewTranscriptButton"
                            Content="View"
                            Click="ViewTranscript_Click"
                            Style="{StaticResource PabloSecondaryButton}"
                            Padding="8,4"
                            FontSize="12" />
                </StackPanel>
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="16"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <TextBlock x:Name="TranscriptPreviewText"
                               Style="{StaticResource PabloBodySmall}"
                               Foreground="{StaticResource PabloBrownSoft}"
                               MaxLines="3"
                               TextTrimming="CharacterEllipsis" />
                </Border>
            </StackPanel>

            <!-- Local transcription section -->
            <StackPanel Spacing="8" x:Name="LocalTranscriptSection" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Local Transcription"
                               Style="{StaticResource PabloBodyLarge}"
                               FontWeight="SemiBold" />
                    <!-- Pending upload badge -->
                    <Border x:Name="PendingUploadBadge"
                            Visibility="Collapsed"
                            Background="#FFF3E0"
                            CornerRadius="4"
                            Padding="8,2"
                            VerticalAlignment="Center">
                        <TextBlock Text="Pending upload"
                                   FontSize="11"
                                   Foreground="#E65100" />
                    </Border>
                </StackPanel>

                <!-- Transcribe button + quality selector -->
                <StackPanel x:Name="TranscribeControls" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="TranscribeButton"
                            Content="Transcribe"
                            Click="Transcribe_Click"
                            Style="{StaticResource PabloPrimaryButton}"
                            Padding="12,6"
                            AutomationProperties.Name="Transcribe this session locally" />
                    <ComboBox x:Name="QualityDropdown"
                              SelectedIndex="0"
                              AutomationProperties.Name="Transcription quality">
                        <ComboBoxItem Content="Fast (small)" Tag="Fast" />
                        <ComboBoxItem Content="Balanced (large-v3-turbo)" Tag="Balanced" />
                        <ComboBoxItem Content="Accurate (large-v3)" Tag="Accurate" />
                    </ComboBox>
                </StackPanel>

                <!-- Progress -->
                <StackPanel x:Name="TranscriptionProgress" Visibility="Collapsed" Spacing="4">
                    <ProgressBar x:Name="TranscriptionProgressBar"
                                 Minimum="0" Maximum="100"
                                 IsIndeterminate="False" />
                    <TextBlock x:Name="TranscriptionStatusText"
                               Style="{StaticResource PabloBodySmall}"
                               Foreground="{StaticResource PabloBrownSoft}" />
                </StackPanel>

                <!-- Local transcript preview -->
                <Border x:Name="LocalTranscriptPreview"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="16"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="LocalTranscriptText"
                                   Style="{StaticResource PabloBodySmall}"
                                   Foreground="{StaticResource PabloBrownSoft}"
                                   MaxLines="5"
                                   TextTrimming="CharacterEllipsis" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="View Full Transcript"
                                    Click="ViewLocalTranscript_Click"
                                    Style="{StaticResource PabloSecondaryButton}"
                                    Padding="8,4"
                                    FontSize="12"
                                    AutomationProperties.Name="View full local transcript" />
                            <Button x:Name="RetryUploadButton"
                                    Content="Retry Upload"
                                    Click="RetryUpload_Click"
                                    Style="{StaticResource PabloSecondaryButton}"
                                    Padding="8,4"
                                    FontSize="12"
                                    Visibility="Collapsed"
                                    AutomationProperties.Name="Retry uploading transcript" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
