<UserControl
    x:Class="PabloCompanion.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource PabloCream}">
        <StackPanel Spacing="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="400"
                    Padding="40">

            <!-- Pablo bear (same artwork as the app icon) -->
            <Border CornerRadius="32"
                    Width="160"
                    Height="160"
                    HorizontalAlignment="Center"
                    AutomationProperties.AccessibilityView="Raw">
                <Border.Background>
                    <ImageBrush ImageSource="ms-appx:///Images/PabloBear.png"
                                Stretch="UniformToFill" />
                </Border.Background>
            </Border>

            <TextBlock Text="Welcome to Pablo"
                       Style="{StaticResource PabloDisplayLarge}"
                       HorizontalAlignment="Center" />

            <TextBlock Text="Sign in to get started"
                       Style="{StaticResource PabloBodyMedium}"
                       Foreground="{StaticResource PabloBrownSoft}"
                       HorizontalAlignment="Center" />

            <!-- Server URL (hidden by default — visible only for self-host / dev) -->
            <TextBox x:Name="ServerUrlBox"
                     Header="Server URL"
                     PlaceholderText="https://app.pablo.health"
                     Text="{x:Bind ViewModel.ServerUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Visibility="{x:Bind ViewModel.IsAdvancedVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                     AutomationProperties.Name="Server URL" />

            <!-- Single Sign In button -->
            <Button Content="Sign in"
                    Command="{x:Bind ViewModel.SignInCommand}"
                    Style="{StaticResource PabloPrimaryButton}"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="Sign in using your browser" />

            <!-- "Connect to a different server" — only shown when advanced is hidden -->
            <HyperlinkButton Content="Connect to a different server"
                             Command="{x:Bind ViewModel.ShowAdvancedCommand}"
                             HorizontalAlignment="Center"
                             Visibility="{x:Bind ViewModel.IsAdvancedVisible, Mode=OneWay, Converter={StaticResource InvertedBoolToVisibilityConverter}}"
                             AutomationProperties.Name="Connect to a different Pablo server" />

            <!-- Error -->
            <InfoBar x:Name="ErrorBar"
                     IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToFalseConverter}}"
                     Severity="Error"
                     Title="Error"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />
        </StackPanel>
    </Grid>
</UserControl>
