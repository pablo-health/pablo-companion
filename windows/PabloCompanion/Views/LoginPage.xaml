<UserControl
    x:Class="PabloCompanion.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource PabloCream}">
        <StackPanel Spacing="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="400"
                    Padding="40">
            <!-- Logo / Title -->
            <TextBlock Text="Pablo Companion"
                       Style="{StaticResource PabloDisplayLarge}"
                       HorizontalAlignment="Center" />

            <TextBlock Text="Sign in to get started"
                       Style="{StaticResource PabloBodyMedium}"
                       Foreground="{StaticResource PabloBrownSoft}"
                       HorizontalAlignment="Center" />

            <!-- Server URL -->
            <TextBox x:Name="ServerUrlBox"
                     Header="Server URL"
                     PlaceholderText="https://your-practice.pablo.health"
                     Text="{x:Bind ViewModel.ServerUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.Name="Server URL" />

            <!-- Single Sign In button -->
            <Button Content="Sign In"
                    Command="{x:Bind ViewModel.SignInCommand}"
                    Style="{StaticResource PabloPrimaryButton}"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="Sign in using your browser" />

            <!-- Error -->
            <InfoBar x:Name="ErrorBar"
                     IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource NullToFalseConverter}}"
                     Severity="Error"
                     Title="Error"
                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />
        </StackPanel>
    </Grid>
</UserControl>
