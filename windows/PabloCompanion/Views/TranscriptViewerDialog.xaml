<ContentDialog
    x:Class="PabloCompanion.Views.TranscriptViewerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Transcript"
    CloseButtonText="Close"
    DefaultButton="Close"
    PrimaryButtonText="Copy All"
    PrimaryButtonClick="CopyAll_Click"
    FullSizeDesired="False">

    <Grid MinWidth="500" MinHeight="300">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      MaxHeight="500"
                      Padding="4">
            <TextBlock x:Name="TranscriptText"
                       FontFamily="Consolas"
                       FontSize="13"
                       TextWrapping="Wrap"
                       IsTextSelectionEnabled="True"
                       Foreground="{StaticResource PabloBrownDeep}" />
        </ScrollViewer>

        <!-- Copy confirmation -->
        <InfoBar x:Name="CopyConfirmation"
                 IsOpen="False"
                 Severity="Success"
                 Title="Copied"
                 Message="Transcript copied to clipboard (auto-clears in 60s)"
                 VerticalAlignment="Bottom"
                 HorizontalAlignment="Stretch" />
    </Grid>
</ContentDialog>
