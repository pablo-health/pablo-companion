<UserControl
    x:Class="PabloCompanion.Views.MinimalShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource PabloCream}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Status + primary CTA -->
        <StackPanel Grid.Row="0"
                    Spacing="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="380"
                    Padding="40">

            <Border CornerRadius="28"
                    Width="120"
                    Height="120"
                    HorizontalAlignment="Center"
                    AutomationProperties.AccessibilityView="Raw">
                <Border.Background>
                    <ImageBrush ImageSource="ms-appx:///Images/PabloBear.png"
                                Stretch="UniformToFill" />
                </Border.Background>
            </Border>

            <!-- Connection status: dot + "Connected to <host> as <email>" -->
            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        HorizontalAlignment="Center">
                <Ellipse x:Name="StatusDot"
                         Width="12"
                         Height="12"
                         VerticalAlignment="Center"
                         Fill="{StaticResource PabloSage}" />
                <TextBlock x:Name="StatusText"
                           Style="{StaticResource PabloBodyMedium}"
                           Foreground="{StaticResource PabloBrownDeep}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="300" />
            </StackPanel>

            <!-- Mic-ready indicator -->
            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        HorizontalAlignment="Center">
                <Ellipse x:Name="MicDot"
                         Width="12"
                         Height="12"
                         VerticalAlignment="Center"
                         Fill="{StaticResource PabloSage}" />
                <TextBlock x:Name="MicText"
                           Style="{StaticResource PabloBodySmall}"
                           Foreground="{StaticResource PabloBrownSoft}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <Button Content="Open Web Dashboard"
                    Click="OpenDashboard_Click"
                    Style="{StaticResource PabloPrimaryButton}"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="Open the Pablo web dashboard in your browser" />
        </StackPanel>

        <!-- Footer: account / sign-out / preferences / version -->
        <Grid Grid.Row="1"
              Padding="20,12"
              ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="VersionText"
                       Grid.Column="0"
                       Style="{StaticResource PabloBodySmall}"
                       Foreground="{StaticResource PabloBrownSoft}"
                       VerticalAlignment="Center" />

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="8">
                <HyperlinkButton Content="Preferences"
                                 Click="Preferences_Click"
                                 AutomationProperties.Name="Open preferences" />
                <HyperlinkButton Content="Sign out"
                                 Click="SignOut_Click"
                                 AutomationProperties.Name="Sign out" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
