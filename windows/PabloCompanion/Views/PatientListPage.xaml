<Page
    x:Class="PabloCompanion.Views.PatientListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource PabloCream}">

    <Grid Padding="32" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Patients"
                   Style="{StaticResource PabloDisplayLarge}" />

        <AutoSuggestBox Grid.Row="1"
                        x:Name="SearchBox"
                        PlaceholderText="Search patients..."
                        QueryIcon="Find"
                        TextChanged="SearchBox_TextChanged"
                        AutomationProperties.Name="Search patients" />

        <!-- Error banner -->
        <InfoBar Grid.Row="2"
                 x:Name="ErrorBanner"
                 IsOpen="False"
                 Severity="Error"
                 Title="Error"
                 HorizontalAlignment="Stretch" />

        <Grid Grid.Row="3">
            <ProgressRing x:Name="LoadingRing"
                          IsActive="False"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />

            <ListView x:Name="PatientList"
                      SelectionMode="None"
                      AutomationProperties.Name="Patient list">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12,10"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="8"
                                Margin="0,3"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Initials avatar -->
                                <Border Grid.Column="0"
                                        Width="40" Height="40"
                                        CornerRadius="20"
                                        Background="{StaticResource PabloHoney}"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="InitialsText"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="White" />
                                </Border>

                                <!-- Name + details -->
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <TextBlock Text="{Binding FirstName}"
                                                   Style="{StaticResource PabloBodyLarge}" />
                                        <TextBlock Text="{Binding LastName}"
                                                   Style="{StaticResource PabloBodyLarge}" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock x:Name="SessionCountText"
                                                   Style="{StaticResource PabloBodySmall}"
                                                   Foreground="{StaticResource PabloBrownSoft}" />
                                        <TextBlock x:Name="LastSessionText"
                                                   Style="{StaticResource PabloBodySmall}"
                                                   Foreground="{StaticResource PabloBrownSoft}" />
                                    </StackPanel>
                                </StackPanel>

                                <!-- Status badge -->
                                <Border x:Name="StatusBadge"
                                        Grid.Column="2"
                                        CornerRadius="12"
                                        Padding="8,4"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="StatusText"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </Border>

                                <!-- Email -->
                                <TextBlock Grid.Column="3"
                                           Text="{Binding Email}"
                                           Style="{StaticResource PabloBodySmall}"
                                           Foreground="{StaticResource PabloBrownSoft}"
                                           VerticalAlignment="Center"
                                           MaxWidth="200"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Empty state -->
            <StackPanel x:Name="EmptyState"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <FontIcon Glyph="&#xE77B;"
                          FontSize="48"
                          Foreground="{StaticResource PabloBrownSoft}" />
                <TextBlock Text="No patients found"
                           Style="{StaticResource PabloBodyMedium}"
                           Foreground="{StaticResource PabloBrownSoft}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
