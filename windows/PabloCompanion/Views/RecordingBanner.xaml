<UserControl
    x:Class="PabloCompanion.Views.RecordingBanner"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{StaticResource PabloSage}"
            CornerRadius="8"
            Padding="12,8"
            x:Name="BannerBorder">
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Recording indicator dot -->
            <Ellipse Grid.Column="0"
                     x:Name="RecordingDot"
                     Width="10" Height="10"
                     Fill="#FFFFFF"
                     VerticalAlignment="Center"
                     AutomationProperties.Name="Recording status indicator" />

            <!-- Status text -->
            <TextBlock Grid.Column="1"
                       x:Name="StatusText"
                       Text="Recording"
                       Foreground="White"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />

            <!-- Duration -->
            <TextBlock Grid.Column="2"
                       x:Name="DurationText"
                       Text="00:00:00"
                       Foreground="#E0FFFFFF"
                       FontFamily="Consolas"
                       VerticalAlignment="Center" />

            <!-- System audio indicator -->
            <StackPanel Grid.Column="3"
                        Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center">
                <Ellipse x:Name="SystemAudioDot"
                         Width="8" Height="8"
                         Fill="#80FFFFFF"
                         VerticalAlignment="Center" />
                <TextBlock Text="System Audio"
                           Foreground="#C0FFFFFF"
                           FontSize="12"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Stop button -->
            <Button Grid.Column="5"
                    x:Name="StopButton"
                    Content="Stop"
                    Click="StopButton_Click"
                    Background="#C45B4A"
                    Foreground="White"
                    Padding="16,6"
                    CornerRadius="4"
                    VerticalAlignment="Center"
                    AutomationProperties.Name="Stop recording" />
        </Grid>
    </Border>
</UserControl>
