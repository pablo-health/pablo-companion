<UserControl
    x:Class="PabloCompanion.Views.RecordingBanner"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PabloCompanion.Views">

    <Border Background="{StaticResource PabloSage}"
            CornerRadius="8"
            Padding="12,8"
            x:Name="BannerBorder">
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Recording indicator dot -->
            <Ellipse Grid.Column="0"
                     x:Name="RecordingDot"
                     Width="10" Height="10"
                     Fill="#FFFFFF"
                     VerticalAlignment="Center"
                     AutomationProperties.Name="Recording status indicator" />

            <!-- Status text -->
            <TextBlock Grid.Column="1"
                       x:Name="StatusText"
                       Text="Recording"
                       Foreground="White"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />

            <!-- Duration -->
            <TextBlock Grid.Column="2"
                       x:Name="DurationText"
                       Text="00:00:00"
                       Foreground="#E0FFFFFF"
                       FontFamily="Consolas"
                       VerticalAlignment="Center" />

            <!-- Volume meters -->
            <local:LevelMeter Grid.Column="3"
                              x:Name="MicMeter"
                              Label="Mic" />

            <local:LevelMeter Grid.Column="4"
                              x:Name="SysMeter"
                              Label="Sys" />

            <!-- System audio indicator -->
            <StackPanel Grid.Column="5"
                        Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center">
                <Ellipse x:Name="SystemAudioDot"
                         Width="8" Height="8"
                         Fill="#80FFFFFF"
                         VerticalAlignment="Center" />
                <TextBlock Text="System Audio"
                           Foreground="#C0FFFFFF"
                           FontSize="12"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Stop Recording + End Session buttons -->
            <StackPanel Grid.Column="7" Orientation="Horizontal" Spacing="8">
                <Button x:Name="StopRecordingButton"
                        Content="Stop Recording"
                        Click="StopRecordingButton_Click"
                        Background="#8B7355"
                        Foreground="White"
                        Padding="12,6"
                        CornerRadius="4"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Stop recording only" />
                <Button x:Name="EndSessionButton"
                        Content="End Session"
                        Click="EndSessionButton_Click"
                        Background="#C45B4A"
                        Foreground="White"
                        Padding="12,6"
                        CornerRadius="4"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Stop recording and end session" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
