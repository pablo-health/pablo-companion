<Page
    x:Class="PabloCompanion.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource PabloCream}">

    <ScrollViewer Padding="32">
        <StackPanel Spacing="24" MaxWidth="600">
            <TextBlock Text="Settings"
                       Style="{StaticResource PabloDisplayLarge}" />

            <!-- Account Info -->
            <StackPanel Spacing="8">
                <TextBlock Text="Account"
                           Style="{StaticResource PabloBodyLarge}"
                           FontWeight="SemiBold" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="16"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="EmailText"
                                   Style="{StaticResource PabloBodyMedium}" />
                        <TextBlock x:Name="BackendUrlText"
                                   Style="{StaticResource PabloBodySmall}"
                                   Foreground="{StaticResource PabloBrownSoft}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Health Check -->
            <StackPanel Spacing="8">
                <TextBlock Text="Connection"
                           Style="{StaticResource PabloBodyLarge}"
                           FontWeight="SemiBold" />

                <Button Content="Test Connection"
                        Click="HealthCheck_Click"
                        Style="{StaticResource PabloSecondaryButton}"
                        AutomationProperties.Name="Test backend connection" />

                <InfoBar x:Name="HealthStatus"
                         IsOpen="False" />
            </StackPanel>

            <!-- Audio -->
            <StackPanel Spacing="8">
                <TextBlock Text="Audio"
                           Style="{StaticResource PabloBodyLarge}"
                           FontWeight="SemiBold" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="16"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Microphone"
                                       Style="{StaticResource PabloBodyMedium}" />
                            <ComboBox x:Name="MicDropdown"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="MicDropdown_SelectionChanged"
                                      AutomationProperties.Name="Select microphone" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72E;"
                                      FontSize="16"
                                      Foreground="{StaticResource PabloSage}" />
                            <TextBlock Text="Audio encryption enabled (HIPAA)"
                                       Style="{StaticResource PabloBodySmall}"
                                       Foreground="{StaticResource PabloBrownSoft}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Transcription -->
            <StackPanel Spacing="8">
                <TextBlock Text="Transcription"
                           Style="{StaticResource PabloBodyLarge}"
                           FontWeight="SemiBold" />

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8"
                        Padding="16"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Quality Preset"
                                       Style="{StaticResource PabloBodyMedium}" />
                            <ComboBox x:Name="TranscriptionQualityDropdown"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="TranscriptionQuality_SelectionChanged"
                                      AutomationProperties.Name="Transcription quality preset">
                                <ComboBoxItem Content="Fast (base.en, ~142 MB)" Tag="Fast" />
                                <ComboBoxItem Content="Balanced (small.en, ~466 MB)" Tag="Balanced" />
                                <ComboBoxItem Content="Accurate (medium.en, ~1.5 GB)" Tag="Accurate" />
                            </ComboBox>
                        </StackPanel>

                        <ToggleSwitch x:Name="AutoTranscribeToggle"
                                      Header="Auto-transcribe after recording"
                                      Toggled="AutoTranscribe_Toggled"
                                      AutomationProperties.Name="Toggle automatic transcription" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="ModelStatusText"
                                       Style="{StaticResource PabloBodySmall}"
                                       Foreground="{StaticResource PabloBrownSoft}"
                                       VerticalAlignment="Center" />
                            <Button x:Name="ModelActionButton"
                                    Content="Download Model"
                                    Click="ModelAction_Click"
                                    Style="{StaticResource PabloSecondaryButton}"
                                    Padding="8,4"
                                    AutomationProperties.Name="Download or delete transcription model" />
                        </StackPanel>

                        <ProgressBar x:Name="ModelDownloadProgress"
                                     Minimum="0" Maximum="100"
                                     Visibility="Collapsed" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Version -->
            <StackPanel Spacing="8">
                <TextBlock Text="About"
                           Style="{StaticResource PabloBodyLarge}"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="VersionText"
                           Style="{StaticResource PabloBodySmall}"
                           Foreground="{StaticResource PabloBrownSoft}" />
            </StackPanel>

            <!-- Sign Out -->
            <Button Content="Sign Out"
                    Click="SignOut_Click"
                    Style="{StaticResource PabloDestructiveButton}"
                    AutomationProperties.Name="Sign out of Pablo" />
        </StackPanel>
    </ScrollViewer>
</Page>
