<Window
    x:Class="PabloCompanion.Views.SessionConfirmationWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Start session">

    <Grid Background="{StaticResource PabloCream}">
        <StackPanel Spacing="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="380"
                    Padding="40">

            <TextBlock x:Name="HeadingText"
                       Style="{StaticResource PabloDisplayMedium}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" />

            <TextBlock x:Name="PromptText"
                       Style="{StaticResource PabloBodyLarge}"
                       Foreground="{StaticResource PabloBrownSoft}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />

            <TextBlock x:Name="ConsentHint"
                       Text="Your microphone will not start until you tap Start Recording."
                       Style="{StaticResource PabloBodySmall}"
                       Foreground="{StaticResource PabloBrownSoft}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />

            <!-- Single affirmative action. Mic does not arm until this is tapped. -->
            <Button x:Name="StartRecordingButton"
                    Content="Start Recording"
                    Click="StartRecording_Click"
                    Style="{StaticResource PabloPrimaryButton}"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="Start recording this session" />

            <Button x:Name="DismissButton"
                    Content="Cancel"
                    Click="Cancel_Click"
                    Style="{StaticResource PabloSecondaryButton}"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="Cancel and close" />
        </StackPanel>
    </Grid>
</Window>
