<Window
    x:Class="PabloCompanion.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PabloCompanion.Views"
    Title="Pablo Companion">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Subscription banner — visible across all pages when authenticated -->
        <local:SubscriptionBanner x:Name="SubscriptionBannerControl"
                                  Grid.Row="0" />

        <!-- Login page shown when unauthenticated -->
        <local:LoginPage x:Name="LoginPage"
                         Grid.RowSpan="2"
                         Visibility="Collapsed" />

        <!-- Main navigation shown when authenticated -->
        <NavigationView x:Name="NavView"
                        Grid.Row="1"
                        x:FieldModifier="internal"
                        Visibility="Collapsed"
                        PaneDisplayMode="LeftCompact"
                        CompactModeThresholdWidth="0"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Today" Tag="DayPage">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE787;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Sessions" Tag="SessionHistoryPage">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B7;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Patients" Tag="PatientListPage">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE77B;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Settings" Tag="SettingsPage">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
