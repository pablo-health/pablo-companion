<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary CTA button (Honey) -->
    <Style x:Key="PabloPrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PabloHoney}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Secondary button -->
    <Style x:Key="PabloSecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource PabloBrownDeep}" />
        <Setter Property="BorderBrush" Value="{StaticResource PabloBrownSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,10" />
    </Style>

    <!-- Destructive button (Terracotta Red) -->
    <Style x:Key="PabloDestructiveButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PabloError}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

</ResourceDictionary>
