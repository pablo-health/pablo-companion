<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary CTA button (Honey) -->
    <Style x:Key="PabloPrimaryButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PabloHoney}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Secondary button -->
    <Style x:Key="PabloSecondaryButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource PabloBrownDeep}" />
        <Setter Property="BorderBrush" Value="{StaticResource PabloBrownSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,10" />
    </Style>

    <!-- Destructive button (Terracotta Red) -->
    <Style x:Key="PabloDestructiveButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PabloError}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16,10" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Filter capsule button (inactive) -->
    <Style x:Key="PabloFilterButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource PabloBrownSoft}" />
        <Setter Property="BorderBrush" Value="{StaticResource PabloBrownSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
    </Style>

    <!-- Filter capsule button (active) -->
    <Style x:Key="PabloFilterButtonActive" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource PabloHoney}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
    </Style>

</ResourceDictionary>
